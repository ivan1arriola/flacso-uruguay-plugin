{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "flacso-uruguay/docentes-equipo",
    "title": "Docentes por Equipo",
    "category": "flacso-uruguay",
    "icon": "groups",
    "description": "Muestra una grilla de docentes por equipo o por la pagina actual.",
    "supports": {
        "html": false
